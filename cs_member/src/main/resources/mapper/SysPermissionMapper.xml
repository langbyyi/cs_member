<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cloud.hilang.cs_member.mapper.SysPermissionMapper">

    <!-- 根据权限编码列表查询权限列表 -->
    <select id="selectByPermissionCodes" parameterType="List" resultType="cloud.hilang.cs_member.entity.SysPermission">
        SELECT
            id, permission_code, permission_name
        FROM
            sys_permission
        WHERE
            permission_code IN
            <foreach collection="permissionCodes" item="permissionCode" open="(" separator="," close=")">
                #{permissionCode}
            </foreach>
    </select>

</mapper>