<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cloud.hilang.cs_member.mapper.MemberCardMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="cloud.hilang.cs_member.entity.MemberCard">
        <id column="member_id" property="memberId" />
        <result column="member_no" property="memberNo" />
        <result column="card_status" property="cardStatus" />
        <result column="issue_date" property="issueDate" />
        <result column="expire_date" property="expireDate" />
        <result column="created_time" property="createdTime" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        member_id, member_no, card_status, issue_date, expire_date, created_time
    </sql>

    <!-- 根据会员ID查询会员卡 -->
    <select id="selectByMemberId" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM member_card
        WHERE member_id = #{memberId,jdbcType=BIGINT}
    </select>

    <!-- 根据会员编号查询会员卡 -->
    <select id="selectByMemberNo" parameterType="java.lang.String" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM member_card
        WHERE member_no = #{memberNo,jdbcType=VARCHAR}
    </select>

    <!-- 创建会员卡 -->
    <insert id="insertMemberCard" parameterType="cloud.hilang.cs_member.entity.MemberCard">
        INSERT INTO member_card (
            member_id, member_no, card_status, issue_date, expire_date, created_time
        ) VALUES (
            #{memberCard.memberId,jdbcType=BIGINT},
            #{memberCard.memberNo,jdbcType=VARCHAR},
            #{memberCard.cardStatus,jdbcType=TINYINT},
            #{memberCard.issueDate,jdbcType=TIMESTAMP},
            #{memberCard.expireDate,jdbcType=TIMESTAMP},
            #{memberCard.createdTime,jdbcType=TIMESTAMP}
        )
    </insert>

    <!-- 更新会员卡状态 -->
    <update id="updateCardStatus">
        UPDATE member_card
        SET card_status = #{cardStatus,jdbcType=TINYINT}
        WHERE member_id = #{memberId,jdbcType=BIGINT}
    </update>

</mapper>