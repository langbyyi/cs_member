<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cloud.hilang.cs_member.mapper.SysRoleMapper">

    <!-- 根据角色编码查询角色 -->
    <select id="selectByRoleCode" parameterType="String" resultType="cloud.hilang.cs_member.entity.SysRole">
        SELECT
            id, role_code, role_name, role_type
        FROM
            sys_role
        WHERE
            role_code = #{roleCode}
    </select>

    <!-- 根据用户ID查询角色列表 -->
    <select id="selectRolesByUserId" parameterType="Long" resultType="cloud.hilang.cs_member.entity.SysRole">
        SELECT
            r.id, r.role_code, r.role_name, r.role_type
        FROM
            sys_role r
        INNER JOIN
            sys_user_role ur ON r.id = ur.role_id
        WHERE
            ur.user_id = #{userId}
    </select>

    <!-- 根据角色ID列表查询角色列表 -->
    <select id="selectByRoleIds" parameterType="List" resultType="cloud.hilang.cs_member.entity.SysRole">
        SELECT
            id, role_code, role_name, role_type
        FROM
            sys_role
        WHERE
            id IN
            <foreach collection="roleIds" item="roleId" open="(" separator="," close=")">
                #{roleId}
            </foreach>
    </select>

    <!-- 根据角色编码查找角色 -->
    <select id="findByRoleCode" parameterType="String" resultType="cloud.hilang.cs_member.entity.SysRole">
        SELECT
            id, role_code, role_name, role_type, description
        FROM
            sys_role
        WHERE
            role_code = #{roleCode}
    </select>

    <!-- 根据角色ID查找权限列表 -->
    <select id="findPermissionsByRoleId" parameterType="Long" resultType="String">
        SELECT
            p.permission_code
        FROM
            sys_permission p
        INNER JOIN
            sys_role_permission rp ON p.id = rp.permission_id
        WHERE
            rp.role_id = #{roleId}
    </select>

</mapper>